<ui:FluentWindow x:Class="optiRAM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:optiRAM.ViewModels"
        xmlns:conv="clr-namespace:optiRAM.Converters"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        Title="optiRAM"
        Icon="pack://application:,,,/Resources/app.ico"
        Width="960" Height="660"
        MinWidth="720" MinHeight="480"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        Closing="Window_Closing">

    <ui:FluentWindow.DataContext>
        <vm:MainViewModel/>
    </ui:FluentWindow.DataContext>

    <ui:FluentWindow.Resources>
        <conv:UsagePercentToBrushConverter x:Key="UsageToBrush"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <!-- Override WPF-UI ToggleSwitch min width so it fits in the sidebar -->
        <sys:Double x:Key="ToggleSwitchThemeMinWidth">0</sys:Double>
    </ui:FluentWindow.Resources>

    <ui:FluentWindow.InputBindings>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding OptimizeNowCommand}"/>
        <KeyBinding Key="F5" Command="{Binding RefreshProcessListCommand}"/>
        <KeyBinding Key="T" Modifiers="Ctrl" Command="{Binding ToggleAutoOptimizeCommand}"/>
    </ui:FluentWindow.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITLE BAR -->
        <ui:TitleBar x:Name="AppTitleBar" Grid.Row="0" Title="optiRAM" ShowMaximize="True" ShowMinimize="True"
                     Icon="{ui:ImageIcon 'pack://application:,,,/Resources/app.ico'}"/>

        <DockPanel Grid.Row="1">

            <!-- READ-ONLY MODE BANNER -->
            <Border DockPanel.Dock="Top" Padding="8,5"
                    Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                    BorderBrush="{StaticResource UsageAmberBrush}" BorderThickness="0,0,0,1"
                    Visibility="{Binding IsReadOnlyMode, Converter={StaticResource BoolToVis}}">
                <DockPanel>
                    <ui:Button DockPanel.Dock="Right" Content="Restart as Admin" Padding="10,2"
                            Appearance="Caution"
                            Command="{Binding RestartAsAdminCommand}"/>
                    <TextBlock VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="Running without admin — optimization disabled, monitoring only."/>
                </DockPanel>
            </Border>

            <!-- OPTIMIZATION RESULT NOTIFICATION -->
            <Border DockPanel.Dock="Top" Padding="8,5"
                    Background="{DynamicResource SystemFillColorSuccessBackgroundBrush}"
                    BorderThickness="0,0,0,1"
                    Visibility="{Binding ShowOptimizationResult, Converter={StaticResource BoolToVis}}">
                <Border.BorderBrush>
                    <SolidColorBrush Color="#FF2E8B57" Opacity="0.3"/>
                </Border.BorderBrush>
                <DockPanel>
                    <ui:Button DockPanel.Dock="Right" Content="X" Padding="6,1" FontSize="10"
                            Appearance="Secondary"
                            Command="{Binding DismissResultCommand}"/>
                    <TextBlock VerticalAlignment="Center" FontSize="12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource UsageGreenBrush}"/>
                                <Setter Property="Text" Value="{Binding LastOptimizationResult.Summary}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LastOptimizationResult.Success}" Value="False">
                                        <Setter Property="Foreground" Value="{StaticResource UsageRedBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </DockPanel>
            </Border>

            <!-- STATUS BAR -->
            <StatusBar DockPanel.Dock="Bottom" FontSize="11">
                <StatusBarItem>
                    <TextBlock>
                        <Run Text="{Binding StatusText, Mode=OneWay}"/>
                    </TextBlock>
                </StatusBarItem>
                <Separator/>
                <StatusBarItem>
                    <TextBlock>
                        <Run Text="Freed "/>
                        <Run Text="{Binding TotalFreedMB, StringFormat='{}{0:F0} MB', Mode=OneWay}" FontWeight="SemiBold"/>
                        <Run Text=" ("/>
                        <Run Text="{Binding OptimizationCount, Mode=OneWay}"/>
                        <Run Text=" runs)"/>
                    </TextBlock>
                </StatusBarItem>
                <Separator/>
                <StatusBarItem>
                    <TextBlock>
                        <Run Text="Auto: "/>
                        <Run Text="{Binding AutoOptimizeEnabled, Mode=OneWay}" FontWeight="SemiBold"/>
                        <Run Text="  Level: "/>
                        <Run Text="{Binding SelectedLevel, Mode=OneWay}" FontWeight="SemiBold"/>
                    </TextBlock>
                </StatusBarItem>
            </StatusBar>

            <!-- HEADER -->
            <Border DockPanel.Dock="Top" Padding="12,8"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1">
                <DockPanel>
                    <ui:Button DockPanel.Dock="Right" Padding="16,6" Margin="10,0,0,0"
                            Appearance="Primary"
                            Command="{Binding OptimizeNowCommand}">
                        <ui:Button.Content>
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Optimize Now"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsOptimizing}" Value="True">
                                                <Setter Property="Text" Value="Optimizing..."/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </ui:Button.Content>
                    </ui:Button>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Margin="0,0,0,4" FontSize="13">
                            <Run Text="RAM  " Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <Run Text="{Binding UsedGB, StringFormat='{}{0:F1}', Mode=OneWay}" FontWeight="Bold" FontSize="15"/>
                            <Run Text="{Binding TotalGB, StringFormat=' / {0:F1} GB', Mode=OneWay}"
                                 Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <Run Text="    "/>
                            <Run Text="{Binding UsagePercent, StringFormat='{}{0:F0}%', Mode=OneWay}"
                                 FontWeight="Bold" FontSize="15"
                                 Foreground="{Binding UsagePercent, Converter={StaticResource UsageToBrush}}"/>
                            <Run Text="    Available " Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <Run Text="{Binding AvailableGB, StringFormat='{}{0:F1} GB', Mode=OneWay}" FontWeight="SemiBold"/>
                        </TextBlock>
                        <ProgressBar Value="{Binding UsagePercent, Mode=OneWay}"
                                     Minimum="0" Maximum="100"
                                     Height="6"
                                     Foreground="{Binding UsagePercent, Converter={StaticResource UsageToBrush}}"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- MAIN CONTENT -->
            <Grid Margin="8,6,8,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: Settings -->
                <Border Grid.Column="0" Margin="0,0,6,0" Padding="8"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="2">

                            <TextBlock Text="Settings" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>

                            <!-- Optimization Mode -->
                            <TextBlock Text="OPTIMIZATION" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,6"/>

                            <ComboBox SelectedItem="{Binding SelectedLevel}" Margin="0,0,0,8"
                                      ToolTip="Conservative: trim working sets only&#x0a;Balanced: + modified flush, standby purge (low-pri), cache flush&#x0a;Aggressive: + full standby purge, system working set empty">
                                <sys:String>Conservative</sys:String>
                                <sys:String>Balanced</sys:String>
                                <sys:String>Aggressive</sys:String>
                            </ComboBox>

                            <ui:ToggleSwitch IsChecked="{Binding AutoOptimizeEnabled}" Margin="0,0,0,4"
                                          ToolTip="Trigger optimization when RAM usage exceeds the threshold"
                                          OnContent="Auto-optimize" OffContent="Auto-optimize"/>

                            <DockPanel Margin="8,4,0,0"
                                       ToolTip="RAM usage % that triggers auto-optimization">
                                <TextBlock Text="Threshold" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                <TextBlock HorizontalAlignment="Right" FontSize="11"
                                           Text="{Binding ThresholdPercent, StringFormat='{}{0}%'}"/>
                            </DockPanel>
                            <Slider Value="{Binding ThresholdPercent}" Minimum="10" Maximum="95"
                                    TickFrequency="5" IsSnapToTickEnabled="True" Margin="8,0,0,6"/>

                            <DockPanel Margin="8,0,0,0"
                                       ToolTip="Minimum seconds between auto-optimizations">
                                <TextBlock Text="Cooldown" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                <TextBlock HorizontalAlignment="Right" FontSize="11"
                                           Text="{Binding CooldownSeconds, StringFormat='{}{0}s'}"/>
                            </DockPanel>
                            <Slider Value="{Binding CooldownSeconds}" Minimum="5" Maximum="300"
                                    TickFrequency="5" IsSnapToTickEnabled="True" Margin="8,0,0,6"/>

                            <ui:ToggleSwitch IsChecked="{Binding ScheduledOptimizeEnabled}" Margin="0,4,0,4"
                                          ToolTip="Run optimization on a fixed interval regardless of memory pressure"
                                          OnContent="Scheduled optimize" OffContent="Scheduled optimize"/>

                            <DockPanel Margin="8,0,0,0"
                                       ToolTip="How often to run scheduled optimization">
                                <TextBlock Text="Every" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                <TextBlock HorizontalAlignment="Right" FontSize="11"
                                           Text="{Binding ScheduledOptimizeIntervalMinutes, StringFormat='{}{0} min'}"/>
                            </DockPanel>
                            <Slider Value="{Binding ScheduledOptimizeIntervalMinutes}" Minimum="1" Maximum="240"
                                    TickFrequency="1" IsSnapToTickEnabled="True" Margin="8,0,0,2"/>

                            <Separator Margin="0,8,0,8"/>

                            <!-- Advanced (collapsed by default) -->
                            <Expander Header="Advanced" IsExpanded="False" Margin="0,0,0,4">
                                <StackPanel Margin="0,4,0,0">
                                    <DockPanel Margin="0,0,0,0"
                                               ToolTip="How often to poll system memory (seconds)">
                                        <TextBlock Text="Poll interval" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock HorizontalAlignment="Right" FontSize="11"
                                                   Text="{Binding CheckIntervalSeconds, StringFormat='{}{0}s'}"/>
                                    </DockPanel>
                                    <Slider Value="{Binding CheckIntervalSeconds}" Minimum="1" Maximum="60"
                                            TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,0,0,6"/>

                                    <DockPanel Margin="0,0,0,0"
                                               ToolTip="Limit Windows file cache to this % of total RAM (0 = off)">
                                        <TextBlock Text="Cache cap" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock HorizontalAlignment="Right" FontSize="11">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding CacheMaxPercent, StringFormat='{}{0}%'}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CacheMaxPercent}" Value="0">
                                                            <Setter Property="Text" Value="Off"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DockPanel>
                                    <Slider Value="{Binding CacheMaxPercent}" Minimum="0" Maximum="75"
                                            TickFrequency="5" IsSnapToTickEnabled="True" Margin="0,0,0,6"/>

                                    <DockPanel Margin="0,0,0,0"
                                               ToolTip="Hard limit on optiRAM's own working set (MB)">
                                        <TextBlock Text="Self WS cap" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock HorizontalAlignment="Right" FontSize="11"
                                                   Text="{Binding SelfWorkingSetCapMB, StringFormat='{}{0} MB'}"/>
                                    </DockPanel>
                                    <Slider Value="{Binding SelfWorkingSetCapMB}" Minimum="5" Maximum="100"
                                            TickFrequency="5" IsSnapToTickEnabled="True" Margin="0,0,0,2"/>
                                </StackPanel>
                            </Expander>

                            <Separator Margin="0,8,0,8"/>

                            <!-- System -->
                            <TextBlock Text="SYSTEM" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,6"/>
                            <ui:ToggleSwitch IsChecked="{Binding StartWithWindows}" Margin="0,0,0,4"
                                          ToolTip="Create a scheduled task to launch at logon with admin privileges"
                                          OnContent="Start with Windows" OffContent="Start with Windows"/>

                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- RIGHT -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Memory stats -->
                    <Border Grid.Row="0" Margin="0,0,0,6" Padding="8"
                            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="Memory" FontSize="13" FontWeight="SemiBold" Margin="4,0,0,6"/>
                            <UniformGrid Columns="4" Margin="2">
                                <StackPanel Margin="4,2">
                                    <TextBlock Text="Used" Style="{StaticResource StatLabel}"/>
                                    <TextBlock Text="{Binding UsedGB, StringFormat='{}{0:F2} GB'}" Style="{StaticResource StatValue}"/>
                                </StackPanel>
                                <StackPanel Margin="4,2">
                                    <TextBlock Text="Available" Style="{StaticResource StatLabel}"/>
                                    <TextBlock Text="{Binding AvailableGB, StringFormat='{}{0:F2} GB'}" Style="{StaticResource StatValue}"
                                               Foreground="{StaticResource UsageGreenBrush}"/>
                                </StackPanel>
                                <StackPanel Margin="4,2">
                                    <TextBlock Text="Cached" Style="{StaticResource StatLabel}"/>
                                    <TextBlock Text="{Binding CachedGB, StringFormat='{}{0:F2} GB'}" Style="{StaticResource StatValue}"/>
                                </StackPanel>
                                <StackPanel Margin="4,2">
                                    <TextBlock Text="Modified" Style="{StaticResource StatLabel}"/>
                                    <TextBlock Text="{Binding ModifiedGB, StringFormat='{}{0:F2} GB'}" Style="{StaticResource StatValue}"
                                               Foreground="{StaticResource UsageAmberBrush}"/>
                                </StackPanel>
                                <StackPanel Margin="4,2">
                                    <TextBlock Text="Free" Style="{StaticResource StatLabel}"/>
                                    <TextBlock Text="{Binding FreeGB, StringFormat='{}{0:F2} GB'}" Style="{StaticResource StatValue}"/>
                                </StackPanel>
                                <StackPanel Margin="4,2">
                                    <TextBlock Text="Compressed" Style="{StaticResource StatLabel}"/>
                                    <TextBlock Text="{Binding CompressedMB, StringFormat='{}{0:F0} MB'}" Style="{StaticResource StatValue}"/>
                                </StackPanel>
                                <StackPanel Margin="4,2">
                                    <TextBlock Text="Commit" Style="{StaticResource StatLabel}"/>
                                    <TextBlock Text="{Binding CommitPercent, StringFormat='{}{0:F0}%'}" Style="{StaticResource StatValue}"/>
                                </StackPanel>
                                <StackPanel Margin="4,2">
                                    <TextBlock Text="Processes" Style="{StaticResource StatLabel}"/>
                                    <TextBlock Text="{Binding ProcessCount, Mode=OneWay}" Style="{StaticResource StatValue}"/>
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <!-- Graph -->
                    <Border Grid.Row="1" Margin="0,0,0,6" Padding="0"
                            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="Usage History" FontSize="13" FontWeight="SemiBold" Margin="10,6,0,4"/>
                            <Canvas x:Name="GraphCanvas" Height="90" Margin="2,0,2,6"
                                    ClipToBounds="True" SizeChanged="GraphCanvas_SizeChanged"
                                    MouseMove="GraphCanvas_MouseMove" MouseLeave="GraphCanvas_MouseLeave">
                                <Polygon x:Name="GraphFill" Fill="{StaticResource GraphFillBrush}"/>
                                <Polyline x:Name="GraphLine" Stroke="{StaticResource GraphBlueBrush}" StrokeThickness="1.5"/>
                                <Ellipse x:Name="GraphDot" Width="6" Height="6"
                                         Fill="{StaticResource GraphBlueBrush}" Visibility="Collapsed"/>
                                <Border x:Name="GraphTooltip" Visibility="Collapsed"
                                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                                        CornerRadius="4" Padding="6,3">
                                    <TextBlock x:Name="GraphTooltipText" FontSize="11"/>
                                </Border>
                            </Canvas>
                        </StackPanel>
                    </Border>

                    <!-- Tabs -->
                    <TabControl Grid.Row="2" SelectionChanged="TabControl_SelectionChanged">
                        <TabItem Header="Processes">
                            <DockPanel>
                                <DockPanel DockPanel.Dock="Top" Margin="2,3,2,2">
                                    <ui:Button DockPanel.Dock="Right" Content="Refresh"
                                            Command="{Binding RefreshProcessListCommand}"
                                            Padding="8,2" Margin="4,0,0,0"
                                            Appearance="Secondary"/>
                                    <TextBox Text="{Binding ProcessFilterText, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="4,3"/>
                                </DockPanel>
                                <DataGrid ItemsSource="{Binding FilteredProcesses}" AutoGenerateColumns="False"
                                          CanUserAddRows="False" CanUserDeleteRows="False"
                                          GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                                          IsReadOnly="False" SelectionMode="Single" FontSize="12"
                                          UseLayoutRounding="True" SnapsToDevicePixels="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Process" Binding="{Binding Name}" Width="*" MinWidth="140" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="PID" Binding="{Binding Pid}" Width="60" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Working Set" Binding="{Binding WorkingSetMB, StringFormat='{}{0:F0} MB'}" Width="100" IsReadOnly="True"/>
                                        <DataGridTemplateColumn Header="Exclude" Width="65">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsExcluded, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                                              Command="{Binding DataContext.ToggleExclusionCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                                              CommandParameter="{Binding}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </TabItem>
                        <TabItem Header="History">
                            <ListBox ItemsSource="{Binding OptimizationHistory}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="1,3">
                                            <Border DockPanel.Dock="Left" Width="3" Margin="0,0,6,0" CornerRadius="2">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{StaticResource UsageGreenBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Success}" Value="False">
                                                                <Setter Property="Background" Value="{StaticResource UsageRedBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                            <TextBlock DockPanel.Dock="Right" VerticalAlignment="Top"
                                                       FontSize="10" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                       Text="{Binding Timestamp, StringFormat='HH:mm:ss'}" Margin="8,1,0,0"/>
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" FontSize="12"
                                                           Text="{Binding FreedMB, StringFormat='+ {0:F0} MB freed'}"/>
                                                <TextBlock FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                           Text="{Binding Summary}" TextWrapping="Wrap"/>
                                                <TextBlock FontSize="10" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                           Text="{Binding MethodsSummary}" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </TabItem>
                    </TabControl>

                </Grid>
            </Grid>
        </DockPanel>

        <!-- Loading overlay -->
        <Grid Grid.RowSpan="2"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
              Background="{DynamicResource ApplicationBackgroundBrush}"
              Panel.ZIndex="100">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ui:ProgressRing IsIndeterminate="True" Width="48" Height="48" />
                <TextBlock Text="Loading..."
                           Margin="0,12,0,0"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
